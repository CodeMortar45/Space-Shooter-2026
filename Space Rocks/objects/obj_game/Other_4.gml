{
	audio_stop_all()
	audio_play_sound (snd_music, 0, true);
}

if (room = rm_game2)
{
	audio_stop_all()
	audio_play_sound (snd_music2, 0, true);
}


if (room = rm_game3)
{
	audio_stop_all()
	audio_play_sound (snd_music2, 0, true);
}

if (room = rm_win)
{
